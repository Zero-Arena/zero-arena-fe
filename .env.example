# zero-arena-fe — public Next.js env. Copy to `.env.local` and adjust.

# ─── Chain ────────────────────────────────────────────────────────────────
# 0G Mainnet (chainId 16661). Override to point at a different RPC node
# (e.g. QuickNode / Ankr).
NEXT_PUBLIC_ZEROG_RPC_URL=https://evmrpc.0g.ai

# ─── v0.2 contracts on 0G mainnet ─────────────────────────────────────────
# Matches @zero-arena/contracts dist/addresses.json (mainnet entry). All
# have production defaults baked into lib/chain/contracts.ts, so leaving
# these unset still hits the canonical mainnet deployment.
NEXT_PUBLIC_AGENT_CERTIFICATE_ADDRESS=0x21a5DEA59cfA07B261d389A9554477e137805c2f
NEXT_PUBLIC_ZERO_ARENA_INFT_ADDRESS=0x4Bd4d45f206861aa7cD4421785a316A1dD06036f
NEXT_PUBLIC_REENCRYPTION_ORACLE_ADDRESS=0x63909dA30b0d65ad72b32b3C8C82515f7BFA6Fd6
NEXT_PUBLIC_LIVE_CERTIFICATE_ADDRESS=0x168c244c872f5FC2D737D3126D08e9EEE45fFbc7
NEXT_PUBLIC_SEASON_ADDRESS=0x4e900860565F9D399B7295c0D28CC7954202524e

# ─── Backend services (zero-arena-be on Railway, Singapore region) ────────
# Transfer-oracle has a production default in lib/be/transfer-oracle.ts; the
# onboard URL has NO default — the "Delegate agent" dialog feature-gates on
# this var being set. To enable owner-delegation UX, set it here AND in
# Vercel project settings.
NEXT_PUBLIC_TRANSFER_ORACLE_URL=https://transfer-oracle-production-f390.up.railway.app
NEXT_PUBLIC_ONBOARD_URL=https://onboard-production-ed6c.up.railway.app

# ─── WalletConnect ────────────────────────────────────────────────────────
# Create a project at https://cloud.walletconnect.com and paste its projectId.
# Without a real ID only injected wallets (MetaMask / Rabby browser ext) work;
# WalletConnect-based mobile wallets (Rainbow, Trust, …) silently fail to
# connect. Vercel production deployments MUST set this in dashboard env vars.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID
